# ============================================================================
# KiCAD Prism - Configuration
# ============================================================================
# This single .env file configures the entire application (both frontend and backend).
# Copy this file to .env and customize for your environment.

# ===========================================
# Service Port
# ===========================================
# Port where the application will be accessible on your host (both frontend and backend API)
# The application runs on port 80 inside the container and is mapped to this port
PORT=8080

# ===========================================
# Application Settings
# ===========================================
# Friendly workspace display name shown on the login page
WORKSPACE_NAME=KiCAD Prism

# Application URL (used in verification/reset emails and OAuth callbacks)
# IMPORTANT: Use the port from PORT above (default 8080)
# Examples:
#   http://localhost:8080           (local development)
#   http://192.168.1.100:8080       (LAN access by IP)
#   https://prism.yourcompany.com   (production with domain)
APP_URL=http://localhost:8080

# ===========================================
# Authentication Settings
# ===========================================
# Set to false to disable authentication entirely (NOT recommended for production)
AUTH_ENABLED=true

# Set to false for production, true only for development/testing
DEV_MODE=false

# ===========================================
# Google OAuth Configuration
# ===========================================
# Get your Client ID from: https://console.cloud.google.com/apis/credentials
# Leave empty if only using GitHub OAuth or email/password authentication
GOOGLE_CLIENT_ID=

# ===========================================
# User Access Control
# ===========================================
# Primary admin account - auto-created on first startup
# The password is only used during initial account creation
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional: Additional admin emails (comma-separated)
BOOTSTRAP_ADMIN_USERS_STR=

# Optional: Email whitelist (comma-separated)
# Leave empty to rely on RBAC role assignments
ALLOWED_USERS_STR=

# Optional: Domain whitelist (comma-separated)
ALLOWED_DOMAINS_STR=

# Optional: Domains that auto-approve new users (comma-separated)
ALLOWED_EMAIL_DOMAINS_STR=

# ===========================================
# Session Management
# ===========================================
# HMAC secret for signing session cookies (required when AUTH_ENABLED=true)
# Generate a long random string: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-secret

# Session lifetime in hours (1-168)
SESSION_TTL_HOURS=12

# Set to true only when serving over HTTPS
SESSION_COOKIE_SECURE=false

# ===========================================
# GitHub OAuth Configuration (for user sign-in)
# ===========================================
# Create OAuth App at: https://github.com/organizations/YOUR_ORG/settings/applications/new
# Authorization callback URL: {APP_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: restrict sign-in to members of this GitHub organization
GITHUB_ORG_LOGIN=

# OAuth scopes for identity verification (repo access uses the GitHub App below)
GITHUB_SCOPES=read:org,user:email

# ===========================================
# GitHub App Configuration (for repo operations)
# ===========================================
# The GitHub App handles all repository browsing, cloning, syncing, and webhooks.
# It operates independently of user OAuth sessions.
#
# Setup steps:
#   1. Create GitHub App: https://github.com/organizations/YOUR_ORG/settings/apps/new
#   2. Required permissions:
#        - Contents: Read-only
#        - Administration: Read-only
#        - Issues: Read-only
#        - Pull requests: Read-only
#   3. Subscribe to events: Create, Commit comments, Issues, Push
#   4. Set Webhook URL: {APP_URL}/api/github/webhook
#   5. Install the App on your organization and note the Installation ID

# Numeric App ID from the App settings page
GITHUB_APP_ID=

# RSA private key - CHOOSE ONE FORMAT:
# Option 1 (recommended): Base64-encoded PEM file
#   Linux/macOS: base64 -w 0 private-key.pem
#   Windows: certutil -encode private-key.pem temp.b64 && findstr /v /c:- temp.b64
GITHUB_APP_PRIVATE_KEY=

# Option 2: Absolute path to .pem file (useful with Docker secrets)
# GITHUB_APP_PRIVATE_KEY=/run/secrets/github-app.pem

# Installation ID for your organization
# Find at: https://github.com/organizations/YOUR_ORG/settings/installations
GITHUB_APP_INSTALLATION_ID=

# Webhook secret - must match the GitHub App webhook settings
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# ===========================================
# Token Encryption
# ===========================================
# Required when GitHub OAuth is enabled to encrypt stored access tokens
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ===========================================
# Email / SMTP Configuration (optional)
# ===========================================
# Required for email verification and password reset features
# Leave empty to disable email functionality
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

# ===========================================
# Advanced Configuration
# ===========================================
# Path to persistent RBAC role store JSON
# Leave empty to use default: {KICAD_PROJECTS_ROOT}/.rbac_roles.json
ROLE_STORE_PATH=

# GitHub Personal Access Token (legacy - prefer GitHub App)
GITHUB_TOKEN=

# Default base URL for KiCad comments REST API (leave empty to auto-detect)
COMMENTS_API_BASE_URL=
